# Copy this file to .env.local and fill in the values.
# cp .env.local.example .env.local

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API

# Public URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Public anon key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Service role key (server-side only — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ─── Admin console ───────────────────────────────────────────────────────────
# Credentials for the internal /admin route

APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=change-me-local-only

# A long random secret used to sign admin session cookies
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ADMIN_SESSION_SECRET=<random-32-byte-hex-string>

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Found in: Stripe dashboard → Developers → API keys
# Use test keys (sk_test_...) locally — never use live keys for development

STRIPE_SECRET_KEY=sk_test_<your-stripe-test-secret-key>

# Webhook signing secret — run `stripe listen --forward-to localhost:3000/api/billing/webhook`
# and copy the whsec_... value it prints
STRIPE_WEBHOOK_SECRET=whsec_<your-stripe-webhook-secret>

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_<your-resend-api-key>

# The "From" address for reminder emails — must be a verified Resend sender
REMINDER_FROM_EMAIL=reminders@yourdomain.com

# ─── App ─────────────────────────────────────────────────────────────────────
# Base URL of the running app — used for redirect URLs and email links

APP_BASE_URL=http://localhost:3000
