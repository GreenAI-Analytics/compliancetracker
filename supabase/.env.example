# =============================================================================
# Compliance Tracker — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#
# ⚠️  Never commit .env.local to version control.
# =============================================================================

# --- Supabase (required) ----------------------------------------------------
# Find these in your Supabase project dashboard under Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Application (required) -------------------------------------------------
# Used for Stripe redirect URLs, email links, and CORS.
APP_BASE_URL=http://localhost:3000

# --- Admin panel (required for /admin) --------------------------------------
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=your-strong-admin-password
APP_ADMIN_SESSION_SECRET=at-least-16-characters-long-secret

# --- Stripe (required for billing) ------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRICE_ID=price_...

# --- Resend (required for email reminders) ----------------------------------
RESEND_API_KEY=re_...
REMINDER_FROM_EMAIL=reminders@example.com

# --- Optional overrides -----------------------------------------------------
# Set to "true" to allow admin payment tests with live Stripe keys.
# ALLOW_LIVE_PAYMENT_TEST=false
