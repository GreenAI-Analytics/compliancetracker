{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Compliance Rules by Country/NACE",
  "type": "object",
  "required": ["nace", "country", "version", "categories"],
  "properties": {
    "nace": { "type": "string", "pattern": "^[0-9]{2}(\\.[0-9]{2})?$" },
    "country": { "type": "string", "pattern": "^[A-Z]{2}$" },
    "version": { "type": "string" },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "tasks"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "title_key", "summary_key", "frequency"],
              "properties": {
                "id": { "type": "string" },
                "title_key": { "type": "string" },
                "summary_key": { "type": "string" },
                "law_ref": { "type": "string" },
                "regulator": { "type": "string" },
                "frequency": {
                  "type": "string",
                  "enum": ["one_time", "weekly", "monthly", "quarterly", "semiannual", "annual", "custom_rrule", "continuous"]
                },
                "rrule": { "type": "string" },
                "due_rule": { "type": "string", "description": "eg. month=1,day=31 or iso-week=1,weekday=5" },
                "weekend_policy": { "type": "string", "enum": ["none", "previous_business_day", "n/a", "next_business_day"] },
                "evidence_required": { "type": "boolean", "default": false }
              }
            }
          }
        }
      }
    }
  }
}
